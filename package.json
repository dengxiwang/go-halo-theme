    "swiper": "^12.1.2",
    "terser": "^5.46.1",
    "tocbot": "^4.36.4"
  },
  "devDependencies": {
    "@halo-dev/theme-package-cli": "^1.0.0",
    "@iconify-json/tabler": "^1.2.31",
